{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$HOME/plugins/cli-notice-codex/scripts/voice_notice.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$HOME/plugins/cli-notice-codex/scripts/voice_notice.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
